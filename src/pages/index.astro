---
import Base from "../layouts/Base.astro";
import NewsCard from "../components/NewsCard.astro";
import news from "../data/news.json";
import research from "../data/research.json";
import { url } from "../lib/url.js";

const recentNews = news.items.slice(0, 3);
const areas = research.areas;

// Hero carousel: "Resolving" stays fixed; the colored accent line and its gradient
// (c1->c2, echoing a bright tone in each image) change with the BACKGROUND IMAGE.
const heroSlides = [
  { img: "/hero-bg.jpg",   accent: "the Universe", c1: "#fcd34d", c2: "#fb923c" },
  { img: "/hero-bg-2.jpg", accent: "our Galaxy",   c1: "#fde047", c2: "#f59e0b" },  // Local Bubble
  { img: "/hero-bg-3.jpg", accent: "Cosmic Accretion", c1: "#ffc096", c2: "#fc853b" },
  { img: "/hero-bg-4.jpg", morph: "/hero-bg-4b.jpg", accent: "Dark Matter", c1: "#fdb37b", c2: "#f48169" },
];
---
<Base title={null}>
  <!-- Hero -->
  <section class="hero">
    <div class="hero__media" aria-hidden="true">
      <div class="hero__slides">
        {heroSlides.map((s, i) => (
          <div class:list={["hero__slide", { "is-active": i === 0 }]}>
            <img class="hero__img" src={url(s.img)} alt=""
                 fetchpriority={i === 0 ? "high" : undefined}
                 loading={i === 0 ? "eager" : "lazy"} />
            {s.morph && (
              <img class="hero__img hero__img--morph" src={url(s.morph)} alt="" loading="lazy" />
            )}
          </div>
        ))}
      </div>
      <div class="hero__scrim"></div>
    </div>
    <div class="hero__credit-wrap">
      <button type="button" class="hero__credit-btn" aria-expanded="false" aria-label="About the hero image">i</button>
      <div class="hero__credit-card" role="note" hidden>
        <p>Caption</p>
        <p class="hero__credit-line">Image Credit</p>
      </div>
    </div>
    <div class="container hero__inner">
      <h1 class="hero__title">Resolving<br /><span class="hero__accent-stack">{heroSlides.map((s, i) => (
        <span class:list={["hero__accent", { "is-active": i === 0 }]} style={`--c1:${s.c1};--c2:${s.c2}`}>{s.accent}</span>
      ))}</span></h1>
      <p class="hero__lead">
        The Institute for Theory and Computation brings together leading researchers to
        understand how the universe works — from the Big Bang and cosmic structure to
        black holes and exoplanets.
      </p>
    </div>
  </section>

  <!-- Research areas -->
  <section class="section">
    <div class="container">
      <div class="section__head">
        <h2>Our Research</h2>
      </div>
      <div class="grid grid--3 areas">
        {areas.map((a) => (
          <a href={`${url("/research")}#${a.slug}`} class="area-tile" data-reveal>
            <img src={url(`/research/${a.slug}.jpg`)} alt="" loading="lazy" />
            <div class="area-tile__scrim"></div>
            <div class="area-tile__label">
              <h3>{a.name}</h3>
              <span class="area-tile__cta">Explore →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- News -->
  <section class="section">
    <div class="container">
      <div class="section__head section__head--row">
        <div>
          <h2>Recent highlights</h2>
        </div>
        <a href={url("/news")} class="arrow-link">All news</a>
      </div>
      <div class="grid grid--3" data-reveal>
        {recentNews.map((item) => <NewsCard item={item} />)}
      </div>
    </div>
  </section>

</Base>

<script>
  // Hero image credit: click the corner trigger to reveal an animated card.
  function setupHeroCredit() {
    const btn = document.querySelector(".hero__credit-btn");
    const card = document.querySelector(".hero__credit-card");
    if (!btn || !card) return;
    const close = () => { btn.setAttribute("aria-expanded", "false"); card.classList.remove("is-open"); };
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const open = btn.getAttribute("aria-expanded") === "true";
      if (open) { close(); return; }
      btn.setAttribute("aria-expanded", "true");
      card.hidden = false;
      requestAnimationFrame(() => card.classList.add("is-open"));
    });
    document.addEventListener("click", close);
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });
  }
  // Hero background carousel: cross-fade the background slides and their matching
  // accent line (text + color) in sync. A slide with a morph overlay (e.g. the
  // dark-matter FDM->CDM pair) fades that overlay in across the hold time.
  function setupHeroCarousel() {
    const slides = Array.from(document.querySelectorAll(".hero__slide"));
    const accents = Array.from(document.querySelectorAll(".hero__accent"));
    if (slides.length < 2) return;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) return;
    let i = 0, timer = 0;
    const HOLD = 5000;
    const setActive = (n, on) => {
      slides[n] && slides[n].classList.toggle("is-active", on);
      accents[n] && accents[n].classList.toggle("is-active", on);
      if (!on && slides[n]) {
        // reset morph to FDM instantly (no reverse fade) once the slide leaves
        const m = slides[n].querySelector(".hero__img--morph");
        if (m) { m.style.transition = "none"; slides[n].classList.remove("is-morphing");
                 requestAnimationFrame(() => { m.style.transition = ""; }); }
      }
    };
    const tick = () => {
      setActive(i, false);
      i = (i + 1) % slides.length;
      setActive(i, true);
      // if this slide has a morph overlay, start its fade-in after it appears
      const cur = slides[i];
      if (cur.querySelector(".hero__img--morph")) {
        requestAnimationFrame(() => requestAnimationFrame(() => cur.classList.add("is-morphing")));
      }
    };
    const start = () => { if (!timer) timer = setInterval(tick, HOLD); };
    const stop = () => { if (timer) { clearInterval(timer); timer = 0; } };
    document.addEventListener("visibilitychange", () => document.hidden ? stop() : start());
    start();
  }

  function bootHero() { setupHeroCredit(); setupHeroCarousel(); }
  if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", bootHero);
  else bootHero();
</script>

<style>
  /* Hero — full-bleed cosmic image */
  .hero { position: relative; overflow: hidden; background: #0a0918; isolation: isolate; }

  /* hero image credit — faint corner trigger + animated card */
  .hero__credit-wrap { position: absolute; right: 1rem; bottom: 1rem; z-index: 3; text-align: right; }
  .hero__credit-btn {
    border: 0; cursor: pointer; padding: 0;
    width: 1.6rem; height: 1.6rem; border-radius: 50%;
    display: grid; place-items: center;
    font-family: var(--font-serif); font-style: italic; font-size: 1rem; line-height: 1;
    color: rgba(255,255,255,.85); background: rgba(10,9,18,.45); backdrop-filter: blur(6px);
    box-shadow: 0 1px 6px rgba(0,0,0,.35), inset 0 0 0 1px rgba(255,255,255,.18);
    transition: background .15s ease, color .15s ease;
  }
  .hero__credit-btn:hover { background: var(--accent); color: #0a0918; }
  .hero__credit-card {
    position: absolute; right: 0; bottom: calc(100% + .5rem); z-index: 4;
    width: max-content; max-width: 280px; text-align: left;
    padding: .8rem 1rem; border-radius: var(--radius);
    background: rgba(10, 9, 18, .62); backdrop-filter: blur(10px);
    box-shadow: 0 8px 28px rgba(0,0,0,.45), inset 0 0 0 1px rgba(255,255,255,.1);
    opacity: 0; transform: translateY(10px) scale(.97); transform-origin: bottom right;
    transition: opacity .32s ease, transform .42s cubic-bezier(.2,.9,.25,1.2);
    pointer-events: none;
  }
  .hero__credit-card.is-open { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
  .hero__credit-card p {
    margin: 0; font-size: .9rem; line-height: 1.5; color: var(--ink);
    opacity: 0; transform: translateY(6px);
    transition: opacity .3s ease .08s, transform .3s ease .08s;
  }
  .hero__credit-card.is-open p { opacity: 1; transform: translateY(0); }
  .hero__credit-line { margin-top: .45rem !important; font-size: .8rem !important; color: var(--ink-faint) !important; transition-delay: .16s !important; }
  @media (prefers-reduced-motion: reduce) {
    .hero__credit-card, .hero__credit-card p { transition: opacity .15s ease; transform: none; }
  }
  .hero__media { position: absolute; inset: 0; z-index: 0; }
  .hero__slides { position: absolute; inset: 0; }
  /* stacked cross-fading background slides (each holds 1-2 layered images) */
  .hero__slide {
    position: absolute; inset: 0;
    opacity: 0; transition: opacity 1.8s ease-in-out;
  }
  .hero__slide.is-active { opacity: 1; }
  .hero__img {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover; object-position: center;
  }
  /* morph overlay (CDM over FDM): hold FDM ~2s, cross-fade 1s, then hold CDM ~2s
     (5s slide window). The 2s delay + 1s duration place the fade in seconds 2-3. */
  .hero__img--morph { opacity: 0; transition: opacity 1s linear 2s; }
  .hero__slide.is-morphing .hero__img--morph { opacity: 1; }
  @media (prefers-reduced-motion: reduce) {
    .hero__slide, .hero__img--morph { transition: none; }
  }
  .hero__scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(90deg, rgba(8,7,18,.85) 0%, rgba(8,7,18,.55) 40%, rgba(8,7,18,.18) 72%, transparent 100%),
      linear-gradient(0deg, rgba(8,7,18,.4) 0%, transparent 45%);
  }
  .hero__inner {
    position: relative; z-index: 1;
    padding-block: clamp(5rem, 12vw, 9rem) clamp(5rem, 12vw, 9rem);
  }
  .hero__inner .hero__title,
  .hero__inner .hero__lead { max-width: 520px; }
  .hero__title {
    font-size: clamp(2.8rem, 6.5vw, 5rem); line-height: 1.02; margin-bottom: 1.4rem;
    letter-spacing: -0.035em; color: #fff;
    text-shadow: 0 2px 30px rgba(0,0,0,.5);
  }
  /* the colored accent line: per-slide spans stacked, cross-fading in sync with
     the background image (text + color both change with the active slide) */
  .hero__accent-stack { position: relative; display: inline-grid; }
  .hero__accent {
    grid-area: 1 / 1;          /* stack all accent variants in one cell */
    white-space: nowrap;
    /* extra bottom room so descenders (y, g) aren't clipped by the text-clip box */
    padding-bottom: .12em; margin-bottom: -.12em;
    background: linear-gradient(90deg, var(--c1, #fcd34d), var(--c2, #fb923c));
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent; color: transparent;
    opacity: 0; transition: opacity 1.8s ease-in-out;
  }
  .hero__accent.is-active { opacity: 1; }
  @media (prefers-reduced-motion: reduce) { .hero__accent { transition: none; } }
  .hero__lead {
    font-size: clamp(1.05rem, 1.6vw, 1.3rem); color: rgba(255,255,255,.82);
    max-width: 600px; text-shadow: 0 1px 16px rgba(0,0,0,.4);
  }


  /* Research image tiles */
  .area-tile {
    position: relative; display: block; overflow: hidden;
    border-radius: var(--radius); aspect-ratio: 5 / 4; background: #0a0918;
    color: #fff; isolation: isolate;
  }
  .area-tile:hover { text-decoration: none; }
  .area-tile img {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
    transition: transform .6s ease;
  }
  .area-tile:hover img { transform: scale(1.06); }
  .area-tile__scrim {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(8,7,18,.05) 30%, rgba(8,7,18,.55) 70%, rgba(8,7,18,.85));
    transition: background .3s ease;
  }
  .area-tile:hover .area-tile__scrim {
    background: linear-gradient(180deg, rgba(8,7,18,.15) 20%, rgba(8,7,18,.6) 60%, rgba(8,7,18,.9));
  }
  .area-tile__label { position: absolute; left: 0; right: 0; bottom: 0; padding: 1.25rem 1.4rem; z-index: 1; }
  .area-tile__label h3 { margin: 0; color: #fff; font-size: 1.3rem; text-shadow: 0 1px 14px rgba(0,0,0,.5); }
  .area-tile__cta {
    display: inline-block; margin-top: .3rem; font-size: .82rem; font-weight: 600;
    color: rgba(255,255,255,.85); opacity: 0; transform: translateY(4px);
    transition: opacity .25s ease, transform .25s ease;
  }
  .area-tile:hover .area-tile__cta { opacity: 1; transform: translateY(0); }

  .section__head--row { display: flex; align-items: flex-end; justify-content: space-between; max-width: none; }
</style>
