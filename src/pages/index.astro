---
import Base from "../layouts/Base.astro";
import NewsCard from "../components/NewsCard.astro";
import news from "../data/news.json";
import research from "../data/research.json";
import people from "../data/people.json";
import { url } from "../lib/url.js";

const recentNews = news.items.slice(0, 3);
const areas = research.areas;
const memberCount = people.groups
  .filter((g) => !/alumni/i.test(g.name))
  .reduce((n, g) => n + g.people.length, 0);
---
<Base title={null}>
  <!-- Hero -->
  <section class="hero">
    <div class="hero__media" aria-hidden="true">
      <img src={url("/hero-bg.jpg")} alt="" fetchpriority="high" />
      <div class="hero__scrim"></div>
    </div>
    <div class="container hero__inner">
      <h1 class="hero__title">Resolving<br /><span class="hero__accent">the Universe.</span></h1>
      <p class="hero__lead">
        The Institute for Theory and Computation brings together leading researchers to
        understand how the universe works — from the Big Bang and cosmic structure to
        black holes and exoplanets.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats-band">
    <div class="container stats">
      <div class="stat"><span class="stat__num">2004</span><span class="stat__label">Founded</span></div>
      <div class="stat"><span class="stat__num">{memberCount}+</span><span class="stat__label">Members &amp; fellows</span></div>
      <div class="stat"><span class="stat__num">200+</span><span class="stat__label">Alumni worldwide</span></div>
    </div>
  </section>

  <!-- Research areas -->
  <section class="section section--soft">
    <div class="container">
      <div class="section__head">
        <h2>Our Research</h2>
        <p>From the formation of galaxies to the physics of black holes, ITC research spans the
          theoretical and computational frontier of modern astrophysics.</p>
      </div>
      <div class="grid grid--3 areas">
        {areas.map((a) => (
          <a href={`${url("/research")}#${a.slug}`} class="area-tile" data-reveal>
            <img src={url(`/research/${a.slug}.jpg`)} alt="" loading="lazy" />
            <div class="area-tile__scrim"></div>
            <div class="area-tile__label">
              <h3>{a.name}</h3>
              <span class="area-tile__cta">Explore →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- News -->
  <section class="section">
    <div class="container">
      <div class="section__head section__head--row">
        <div>
          <h2>Recent highlights</h2>
        </div>
        <a href={url("/news")} class="arrow-link">All news</a>
      </div>
      <div class="grid grid--3" data-reveal>
        {recentNews.map((item) => <NewsCard item={item} />)}
      </div>
    </div>
  </section>

</Base>

<style>
  /* Hero — full-bleed cosmic image */
  .hero { position: relative; overflow: hidden; background: #0a0918; isolation: isolate; }
  .hero__media { position: absolute; inset: 0; z-index: 0; }
  .hero__media img { width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .hero__scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(90deg, rgba(8,7,18,.92) 0%, rgba(8,7,18,.78) 38%, rgba(8,7,18,.35) 68%, rgba(8,7,18,.15) 100%),
      linear-gradient(0deg, rgba(8,7,18,.55) 0%, transparent 45%);
  }
  .hero__inner {
    position: relative; z-index: 1;
    padding-block: clamp(5rem, 12vw, 9rem) clamp(5rem, 12vw, 9rem);
  }
  .hero__inner .hero__title,
  .hero__inner .hero__lead { max-width: 520px; }
  .hero__title {
    font-size: clamp(2.8rem, 6.5vw, 5rem); line-height: 1.02; margin-bottom: 1.4rem;
    letter-spacing: -0.035em; color: #fff;
    text-shadow: 0 2px 30px rgba(0,0,0,.5);
  }
  .hero__accent {
    background: linear-gradient(90deg, #fcd34d, #fb923c);
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent; color: transparent;
  }
  .hero__lead {
    font-size: clamp(1.05rem, 1.6vw, 1.3rem); color: rgba(255,255,255,.82);
    max-width: 600px; text-shadow: 0 1px 16px rgba(0,0,0,.4);
  }

  /* Stats */
  .stats-band {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .stats {
    display: grid; grid-template-columns: repeat(3, 1fr);
    padding-block: clamp(1.75rem, 3vw, 2.5rem);
  }
  .stat {
    display: flex; flex-direction: column; align-items: center; gap: .35rem;
    text-align: center;
  }
  .stat__num {
    font-family: var(--font-serif); font-variant-numeric: tabular-nums;
    font-size: clamp(1.9rem, 3.4vw, 2.6rem); font-weight: 600; color: var(--ink);
    letter-spacing: -0.02em; line-height: 1;
  }
  .stat__label {
    color: var(--ink-faint); font-size: .74rem; font-family: var(--font-sans);
    font-weight: 500; text-transform: uppercase; letter-spacing: .08em;
  }
  @media (max-width: 440px) {
    .stats { grid-template-columns: 1fr; gap: 1.5rem; }
  }

  /* Research image tiles */
  .area-tile {
    position: relative; display: block; overflow: hidden;
    border-radius: var(--radius); aspect-ratio: 5 / 4; background: #0a0918;
    color: #fff; isolation: isolate;
  }
  .area-tile:hover { text-decoration: none; }
  .area-tile img {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
    transition: transform .6s ease;
  }
  .area-tile:hover img { transform: scale(1.06); }
  .area-tile__scrim {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(8,7,18,.05) 30%, rgba(8,7,18,.55) 70%, rgba(8,7,18,.85));
    transition: background .3s ease;
  }
  .area-tile:hover .area-tile__scrim {
    background: linear-gradient(180deg, rgba(8,7,18,.15) 20%, rgba(8,7,18,.6) 60%, rgba(8,7,18,.9));
  }
  .area-tile__label { position: absolute; left: 0; right: 0; bottom: 0; padding: 1.25rem 1.4rem; z-index: 1; }
  .area-tile__label h3 { margin: 0; color: #fff; font-size: 1.3rem; text-shadow: 0 1px 14px rgba(0,0,0,.5); }
  .area-tile__cta {
    display: inline-block; margin-top: .3rem; font-size: .82rem; font-weight: 600;
    color: rgba(255,255,255,.85); opacity: 0; transform: translateY(4px);
    transition: opacity .25s ease, transform .25s ease;
  }
  .area-tile:hover .area-tile__cta { opacity: 1; transform: translateY(0); }

  .section__head--row { display: flex; align-items: flex-end; justify-content: space-between; max-width: none; }
</style>
