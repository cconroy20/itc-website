---
import Base from "../../layouts/Base.astro";
import RichText from "../../components/RichText.astro";
import frontiers from "../../data/frontiers.json";
import { url } from "../../lib/url.js";

export function getStaticPaths() {
  return frontiers.programs.map((program) => ({
    params: { slug: program.slug },
    props: { program },
  }));
}

const { program } = Astro.props;
const { title, dates, body, organizers } = program;
---
<Base title={`${title} · Frontiers`} description={`${title} — an ITC Frontiers program, ${dates}.`}>
  <article class="article">
    <div class="container article__head">
      <a href={url("/frontiers")} class="article__back">← Frontiers</a>
      <h1>{title}</h1>
      <p class="article__dates">{dates}</p>
      {organizers && organizers.length > 0 && (
        <p class="article__organizers">
          <span class="article__organizers-label">Organizers:</span> {organizers.join(", ")}
        </p>
      )}
    </div>

    <div class="container article__body prose">
      <RichText text={body} />
    </div>
  </article>
</Base>

<style>
  .article__head { padding-block: clamp(2rem, 4vw, 2.75rem) 1.5rem; max-width: var(--maxw-prose); }
  .article__back {
    display: inline-block; font-size: .85rem; font-weight: 500; color: var(--ink-soft);
    margin-bottom: 1.25rem;
  }
  .article__back:hover { color: var(--accent-ink); text-decoration: none; }
  .article__head h1 { margin: 0; font-size: clamp(1.7rem, 3.4vw, 2.5rem); letter-spacing: -0.028em; text-wrap: balance; }
  .article__dates {
    margin: .65rem 0 0; font-size: 1.1rem; color: var(--ink-soft);
    font-variant-numeric: tabular-nums;
  }
  .article__organizers { margin: .5rem 0 0; font-size: 1rem; color: var(--ink-soft); }
  .article__organizers-label { color: var(--ink-faint); }

  .article__body { max-width: var(--maxw-prose); padding-bottom: 4rem; }
  .article__body :global(p) { font-size: 1.05rem; }
</style>
