---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import RichText from "../components/RichText.astro";
import pages from "../data/pages.json";
import { url } from "../lib/url.js";

const { directorsWelcome, computingResources, supportItc } = pages;
---
<Base title="About" description="About the Institute for Theory and Computation: our mission, leadership, and computing resources.">
  <PageHero title="About the ITC" />

  <nav class="jump container" aria-label="Jump to section">
    <a href="#welcome" class="jump__link">Director's welcome</a>
    <a href="#computing" class="jump__link">Computing resources</a>
    <a href="#support" class="jump__link">Support the ITC</a>
    <a href={url("/contact")} class="jump__link">Contact &amp; location</a>
  </nav>

  <div class="section about-body">
    <div class="container">
      <div class="layout__main prose">
        <section id="welcome" class="block">
          <h2>Director's Welcome</h2>
          <RichText text={directorsWelcome.body} />
        </section>

        <section id="computing" class="block">
          <h2>Computing Resources</h2>
          <RichText text={computingResources.body} />
        </section>

        <section id="support" class="block">
          <h2>Support the ITC</h2>
          <RichText text={supportItc.body} />
          <p><a href={url("/contact")} class="arrow-link">Get in touch</a></p>
        </section>
      </div>
    </div>
  </div>
</Base>

<style>
  .jump {
    display: flex; gap: .5rem; flex-wrap: wrap;
    padding-block: 1.25rem; border-bottom: 1px solid var(--line);
    position: sticky; top: 72px; background: transparent; backdrop-filter: blur(6px); z-index: 50;
  }
  .jump__link {
    font-family: var(--font-sans); font-size: .85rem; font-weight: 500;
    color: var(--ink-soft);
    padding: .4rem .8rem; border: 1px solid var(--line); border-radius: var(--radius); background: var(--bg-soft);
  }
  .jump__link:hover { color: var(--accent-ink); border-color: var(--accent-line); background: var(--accent-soft); text-decoration: none; }

  .about-body { padding-top: clamp(1.75rem, 3vw, 2.5rem); }
  .layout__main { max-width: var(--maxw-prose); }
  .block { scroll-margin-top: 130px; }
  .block + .block { margin-top: 3rem; padding-top: 2.5rem; border-top: 1px solid var(--line); }
</style>
