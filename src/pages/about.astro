---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import RichText from "../components/RichText.astro";
import pages from "../data/pages.json";

const { about, directorsWelcome, computingResources, supportItc } = pages;
---
<Base title="About" description="About the Institute for Theory and Computation: our mission, leadership, and computing resources.">
  <PageHero
    eyebrow="About"
    title="About the ITC"
    lead="Since 2004, the Institute for Theory and Computation has integrated conceptual theory with computation to study the universe."
  />

  <div class="section">
    <div class="container layout">
      <aside class="layout__nav">
        <a href="#mission">Mission</a>
        <a href="#welcome">Director's welcome</a>
        <a href="#computing">Computing resources</a>
        <a href="#support">Support the ITC</a>
        <a href="/contact">Contact &amp; location</a>
      </aside>

      <div class="layout__main prose">
        <section id="mission" class="block">
          <RichText text={about.body} />
        </section>

        <section id="welcome" class="block">
          <h2>Director's Welcome</h2>
          <RichText text={directorsWelcome.body} />
        </section>

        <section id="computing" class="block">
          <h2>Computing Resources</h2>
          <RichText text={computingResources.body} />
        </section>

        <section id="support" class="block">
          <h2>Support the ITC</h2>
          <RichText text={supportItc.body} />
          <p><a href="/contact" class="arrow-link">Get in touch</a></p>
        </section>
      </div>
    </div>
  </div>
</Base>

<style>
  .layout { display: grid; grid-template-columns: 220px 1fr; gap: 3rem; }
  .layout__nav { position: sticky; top: 96px; align-self: start; display: flex; flex-direction: column; gap: .15rem; }
  .layout__nav a { font-size: .92rem; color: var(--ink-soft); padding: .4rem .6rem; border-left: 2px solid var(--line); }
  .layout__nav a:hover { color: var(--accent); border-color: var(--accent); text-decoration: none; }
  .block { scroll-margin-top: 96px; }
  .block + .block { margin-top: 3rem; padding-top: 2.5rem; border-top: 1px solid var(--line); }
  @media (max-width: 800px) {
    .layout { grid-template-columns: 1fr; gap: 1.5rem; }
    .layout__nav { position: static; flex-direction: row; flex-wrap: wrap; }
    .layout__nav a { border-left: none; border: 1px solid var(--line); border-radius: 100px; }
  }
</style>
