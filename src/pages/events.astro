---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";

// Each event type has a list of dated sessions. A session has a `date` and an
// array of `speakers`, each { name, affiliation, title }.
// Luncheons typically have three speakers per session.
const events = [
  {
    slug: "luncheon",
    name: "ITC Luncheon",
    detail: "12:30–1:30, Philips Auditorium",
    sessions: [
      // Each session: date + up to three speakers, each { name, affiliation, title }.
      {
        date: "Sep 10, 2026",
        speakers: [
          { name: "", affiliation: "", title: "" },
          { name: "", affiliation: "", title: "" },
          { name: "", affiliation: "", title: "" },
        ],
      },
    ],
  },
  {
    slug: "special-seminars",
    name: "Special Seminars",
    sessions: [],
  },
];
---
<Base title="Events" description="The ITC Luncheon and Special Seminars at the Institute for Theory and Computation.">
  <PageHero title="Events" />

  <nav class="jump container" aria-label="Jump to event">
    {events.map((e) => <a href={`#${e.slug}`} class="jump__link">{e.name}</a>)}
  </nav>

  <section class="section">
    <div class="container events">
      {events.map((e) => (
        <section id={e.slug} class="event">
          <h2>{e.name}</h2>
          {e.detail && <p class="event__detail">{e.detail}</p>}
          {e.sessions.length > 0 ? (
            <ul class="sessions">
              {e.sessions.map((s) => (
                <li class="session">
                  <span class="session__date">{s.date}</span>
                  <ul class="speakers">
                    {s.speakers.map((sp) => (
                      sp.name || sp.title ? (
                        <li class="speaker">
                          <span class="speaker__who">{sp.name}</span>{sp.affiliation && <span class="speaker__aff"> ({sp.affiliation})</span>}{sp.title && <span class="speaker__title"> “{sp.title}”</span>}
                        </li>
                      ) : (
                        <li class="speaker speaker--empty">—</li>
                      )
                    ))}
                  </ul>
                </li>
              ))}
            </ul>
          ) : (
            <p class="sessions-empty">Schedule coming soon.</p>
          )}
        </section>
      ))}
    </div>
  </section>
</Base>

<style>
  .jump {
    display: flex; gap: .5rem; flex-wrap: wrap;
    padding-block: 1.25rem; border-bottom: 1px solid var(--line);
    position: sticky; top: 72px; background: transparent; backdrop-filter: blur(6px); z-index: 50;
  }
  .jump__link {
    font-family: var(--font-sans); font-size: .85rem; font-weight: 500; color: var(--ink-soft);
    padding: .4rem .8rem; border: 1px solid var(--line); border-radius: var(--radius); background: var(--bg-soft);
  }
  .jump__link:hover { color: var(--accent-ink); border-color: var(--accent-line); background: var(--accent-soft); text-decoration: none; }

  .events { max-width: 900px; display: flex; flex-direction: column; gap: 3rem; }
  .event { scroll-margin-top: 192px; }
  .event h2 { margin: 0 0 .4rem; font-size: clamp(1.5rem, 2.6vw, 2rem); }
  .event__detail { margin: 0 0 1.25rem; color: var(--ink-soft); font-size: 1rem; }

  .sessions { list-style: none; margin: 0; padding: 0; }
  .session {
    display: grid; grid-template-columns: 180px 1fr; gap: 1.5rem;
    padding: 1.4rem 0; border-top: 1px solid var(--line);
  }
  .session:last-child { border-bottom: 1px solid var(--line); }
  .session__date {
    font-family: var(--font-serif); font-size: 1.25rem; color: var(--ink);
    white-space: nowrap; padding-top: .1rem; font-variant-numeric: tabular-nums;
  }

  .speakers { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: .65rem; }
  .speaker { font-size: 1.02rem; line-height: 1.45; color: var(--ink-soft); }
  .speaker__who { font-weight: 600; color: var(--ink); }
  .speaker__aff { color: var(--ink-soft); }
  .speaker__title { color: var(--ink-soft); font-style: italic; }
  .speaker--empty { color: var(--ink-faint); }

  @media (max-width: 560px) {
    .session { grid-template-columns: 1fr; gap: .75rem; }
  }
</style>
