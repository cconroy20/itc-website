---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import NewsCard from "../components/NewsCard.astro";
import news from "../data/news.json";

const items = news.items;
const [feature, ...rest] = items;
const fmt = (d) => d ? new Date(d + "T00:00:00").toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }) : null;
---
<Base title="News" description="News and highlights from the Institute for Theory and Computation.">
  <PageHero eyebrow="News" title="News &amp; highlights" lead="Awards, discoveries, and milestones from across the ITC community." />

  <section class="section">
    <div class="container">
      {feature && (
        <a href={feature.url} class="feature card">
          <div class="feature__body">
            {feature.date && <time class="meta" datetime={feature.date}>{fmt(feature.date)}</time>}
            <h2>{feature.title}</h2>
            {feature.excerpt && <p>{feature.excerpt}</p>}
            <span class="arrow-link">Read more</span>
          </div>
        </a>
      )}

      <div class="grid grid--3 news-grid">
        {rest.map((item) => <NewsCard item={item} />)}
      </div>
    </div>
  </section>
</Base>

<style>
  .feature { display: block; padding: 2rem; margin-bottom: 2.5rem; color: inherit; border-left: 4px solid var(--accent); }
  .feature:hover { text-decoration: none; }
  .feature__body { max-width: 70ch; }
  .feature h2 { margin: .5rem 0 .75rem; }
  .feature p { color: var(--ink-soft); margin: 0 0 1rem; }
</style>
