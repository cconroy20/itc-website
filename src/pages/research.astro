---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import RichText from "../components/RichText.astro";
import research from "../data/research.json";

const areas = research.areas;
---
<Base title="Research" description="Research at the ITC spans galaxies & cosmology, gravity, high-energy astrophysics, planetary astronomy, and stars.">
  <PageHero title="Research at the ITC" lead={research.intro} />

  <nav class="jump container" aria-label="Jump to area">
    {areas.map((a) => <a href={`#${a.slug}`} class="jump__link">{a.name}</a>)}
  </nav>

  <div class="areas">
    {areas.map((a) => (
      <section class="area" id={a.slug} data-reveal>
        <div class="area__media">
          <img src={`/research/${a.slug}.jpg`} alt={`${a.name} — illustrative astrophysics imagery`} loading="lazy" />
        </div>
        <div class="area__body">
          <h2>{a.name}</h2>
          <div class="prose"><RichText text={a.body} /></div>
          {a.people && a.people.length > 0 && (
            <p class="area__people">
              <strong>Faculty &amp; researchers:</strong> {a.people.join(", ")}
            </p>
          )}
        </div>
      </section>
    ))}
  </div>
</Base>

<style>
  .jump {
    display: flex; gap: .5rem; flex-wrap: wrap;
    padding-block: 1.25rem; border-bottom: 1px solid var(--line);
    position: sticky; top: 72px; background: rgba(255,255,255,.92);
    backdrop-filter: blur(8px); z-index: 50;
  }
  .jump__link {
    font-family: var(--font-sans); font-size: .85rem; font-weight: 500;
    color: var(--ink-soft);
    padding: .4rem .8rem; border: 1px solid var(--line); border-radius: var(--radius);
  }
  .jump__link:hover { color: var(--accent-ink); border-color: var(--accent-line); background: var(--accent-soft); text-decoration: none; }

  .areas { display: flex; flex-direction: column; }
  .area {
    display: grid; grid-template-columns: 1fr 1fr; align-items: center;
    gap: clamp(2rem, 5vw, 4.5rem);
    max-width: var(--maxw); margin-inline: auto; width: 100%;
    padding: clamp(3rem, 6vw, 5rem) clamp(1rem, 4vw, 2.5rem);
    scroll-margin-top: 130px;
  }
  .area + .area { border-top: 1px solid var(--line); }
  /* alternate image side */
  .area:nth-child(even) .area__media { order: 2; }

  .area__media {
    position: relative; border-radius: var(--radius); overflow: hidden;
    aspect-ratio: 4 / 3; background: #0a0918;
    box-shadow: 0 10px 40px rgba(20,21,26,.12);
  }
  .area__media img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s ease; }
  .area:hover .area__media img { transform: scale(1.04); }
  .area__media::after {
    content: ""; position: absolute; inset: 0;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,.06);
    background: linear-gradient(180deg, transparent 60%, rgba(8,7,18,.25));
  }

  .area__body h2 { margin: 0 0 1rem; font-size: clamp(1.7rem, 3vw, 2.4rem); }
  .area__people {
    margin-top: 1.5rem; padding-top: 1.1rem; border-top: 1px solid var(--line);
    font-size: .92rem; color: var(--ink-soft);
  }

  @media (max-width: 820px) {
    .area { grid-template-columns: 1fr; gap: 1.75rem; }
    .area:nth-child(even) .area__media { order: 0; }
    .area__media { aspect-ratio: 16 / 9; }
  }
</style>
