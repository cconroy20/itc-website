---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import PersonCard from "../components/PersonCard.astro";
import people from "../data/people.json";

// Show current members on this page; alumni get their own page.
// The Director is shown within Senior ITC Members (no standalone section).
const groups = people.groups.filter((g) => !/alumni/i.test(g.name) && !/director/i.test(g.name));
const slug = (s) => s.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
---
<Base title="People" description="Faculty, fellows, postdocs, and staff of the Institute for Theory and Computation.">
  <PageHero
    eyebrow="People"
    title="People"
    lead="A community of faculty, lecturers, astrophysicists, postdoctoral and predoctoral fellows, visitors, and staff working across theoretical and computational astrophysics."
  />

  <nav class="jump container" aria-label="Jump to group">
    {groups.map((g) => <a href={`#${slug(g.name)}`} class="jump__link">{g.name}</a>)}
  </nav>

  {groups.map((g) => (
    <section class="section people-group" id={slug(g.name)}>
      <div class="container">
        <h2 class="people-group__title">{g.name}</h2>
        <div class="grid grid--4">
          {g.people.map((person) => <PersonCard person={person} />)}
        </div>
      </div>
    </section>
  ))}
</Base>

<style>
  .jump {
    display: flex; gap: .5rem; flex-wrap: wrap;
    padding-block: 1.25rem; border-bottom: 1px solid var(--line);
    position: sticky; top: 72px; background: transparent; backdrop-filter: blur(6px); z-index: 50;
  }
  .jump__link {
    font-family: var(--font-sans); font-size: .85rem; font-weight: 500;
    letter-spacing: 0; color: var(--ink-soft);
    padding: .4rem .8rem; border: 1px solid var(--line); border-radius: var(--radius); background: var(--bg-soft);
  }
  .jump__link:hover { color: var(--accent-ink); border-color: var(--accent-line); background: var(--accent-soft); text-decoration: none; }

  .people-group { padding-block: clamp(2.5rem, 5vw, 3.5rem) 0; scroll-margin-top: 152px; }
  .people-group:last-of-type { padding-bottom: 2rem; }
  .people-group__title { margin-bottom: 1.75rem; }
</style>
