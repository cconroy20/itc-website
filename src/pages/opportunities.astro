---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import RichText from "../components/RichText.astro";
import pages from "../data/pages.json";

const { postdoctoralFellowships, predoctoralFellowships, sabbaticalVisitors } = pages;

const tracks = [
  { key: "postdoc", title: "Postdoctoral Fellowships", data: postdoctoralFellowships },
  { key: "predoc", title: "Predoctoral Fellowships", data: predoctoralFellowships },
  { key: "sabbatical", title: "Sabbatical Visitors", data: sabbaticalVisitors },
];
---
<Base title="Opportunities" description="Postdoctoral and predoctoral fellowships and visiting opportunities at the ITC.">
  <PageHero title="Join the ITC" />

  <nav class="jump container" aria-label="Jump to opportunity">
    {tracks.map((t) => <a href={`#${t.key}`} class="jump__link">{t.title}</a>)}
  </nav>

  <section class="section">
    <div class="container">
      <div class="details">
        {tracks.map((t) => (
          <section id={t.key} class="detail">
            <h2>{t.title}</h2>
            <RichText text={t.data.body} />
          </section>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .jump {
    display: flex; gap: .5rem; flex-wrap: wrap;
    padding-block: 1.25rem; border-bottom: 1px solid var(--line);
    position: sticky; top: 72px; background: transparent; backdrop-filter: blur(6px); z-index: 50;
  }
  .jump__link {
    font-family: var(--font-sans); font-size: .85rem; font-weight: 500;
    color: var(--ink-soft);
    padding: .4rem .8rem; border: 1px solid var(--line); border-radius: var(--radius); background: var(--bg-soft);
  }
  .jump__link:hover { color: var(--accent-ink); border-color: var(--accent-line); background: var(--accent-soft); text-decoration: none; }

  .details { display: flex; flex-direction: column; gap: 3rem; max-width: 860px; }
  .detail { scroll-margin-top: 152px; }
  .detail + .detail { padding-top: 2.5rem; border-top: 1px solid var(--line); }
</style>
