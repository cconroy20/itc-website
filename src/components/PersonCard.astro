---
import { url } from "../lib/url.js";
const { person } = Astro.props;
const { name, email, title, photo, website } = person;
const initials = name.split(/\s+/).map((n) => n[0]).slice(0, 2).join("").toUpperCase();
---
<article class="person card">
  <div class="person__photo">
    {photo
      ? <img src={url(photo)} alt={name} loading="lazy" width="320" height="400" />
      : <div class="person__placeholder" aria-hidden="true">{initials}</div>}
  </div>
  <div class="person__body">
    <h3 class="person__name">{name}</h3>
    {title && <p class="person__title">{title}</p>}
    <div class="person__links">
      {email && (
        <a class="person__link" href={`mailto:${email}`} aria-label={`Email ${name}`}>
          <svg class="person__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="2"/>
            <path d="M4 7l8 6 8-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Email
        </a>
      )}
      {website && (
        <a class="person__link" href={website} target="_blank" rel="noopener" aria-label={`${name}'s website`}>
          <svg class="person__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/>
            <path d="M3 12h18M12 3c2.5 2.5 2.5 15.5 0 18M12 3c-2.5 2.5-2.5 15.5 0 18" stroke="currentColor" stroke-width="2"/>
          </svg>
          Website
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .person { display: flex; flex-direction: column; height: 100%; }
  .person__photo { aspect-ratio: 4 / 5; background: var(--bg-sky); overflow: hidden; }
  .person__photo img { width: 100%; height: 100%; object-fit: cover; }
  .person__placeholder {
    width: 100%; height: 100%; display: grid; place-items: center;
    font-family: var(--font-serif); font-size: 2rem; color: var(--accent);
    background: linear-gradient(135deg, var(--accent-soft), var(--bg-sky));
  }
  .person__body { padding: 1.1rem 1.1rem 1.25rem; display: flex; flex-direction: column; gap: .15rem; flex: 1; }
  .person__name { font-size: 1.1rem; margin: 0; }
  .person__title { color: var(--ink-soft); font-size: .9rem; margin: .1rem 0 0; }
  .person__links {
    margin-top: auto; padding-top: .7rem;
    display: flex; flex-wrap: wrap; gap: .25rem 1rem;
  }
  .person__link {
    display: inline-flex; align-items: center; gap: .35rem;
    font-size: .85rem; font-weight: 500; color: var(--accent-ink);
  }
  .person__icon { flex-shrink: 0; opacity: .8; }
  .person__link:hover { text-decoration: none; color: var(--accent); }
  .person__link:hover .person__icon { opacity: 1; }
</style>
