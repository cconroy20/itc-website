---
import { url } from "../lib/url.js";
---
<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__col">
      <h4>Explore</h4>
      <a href={url("/about")}>About</a>
      <a href={url("/research")}>Research</a>
      <a href={url("/people")}>People</a>
      <a href={url("/events")}>Events</a>
      <a href={url("/opportunities")}>Opportunities</a>
      <a href={url("/news")}>News</a>
    </div>

    <div class="site-footer__col">
      <h4>Contact</h4>
      <p class="meta">
        60 Garden St., MS 51<br />
        Cambridge, MA 02138<br />
        <a href="mailto:itcinfo@cfa.harvard.edu">itcinfo@cfa.harvard.edu</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer { background: var(--bg-soft); color: var(--ink-soft); margin-top: 4rem; border-top: 1px solid var(--line); }
  .site-footer a { color: var(--ink-soft); }
  .site-footer a:hover { color: var(--ink); }
  .site-footer__inner {
    display: flex; flex-wrap: wrap; gap: 2.5rem 5rem;
    padding-block: 3rem 3.25rem;
  }
  .site-footer__col { display: flex; flex-direction: column; gap: .4rem; }
  .site-footer__col h4 { color: var(--ink); font-size: .8rem; text-transform: uppercase; letter-spacing: .1em; margin-bottom: .5rem; font-family: var(--font-sans); }
  .site-footer__col a { font-size: .92rem; }
</style>
