---
const year = 2026;
---
<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <span class="brand__mark" aria-hidden="true">ITC</span>
      <p>
        <strong>Institute for Theory &amp; Computation</strong><br />
        Center for Astrophysics | Harvard &amp; Smithsonian
      </p>
    </div>

    <div class="site-footer__col">
      <h4>Explore</h4>
      <a href="/about">About</a>
      <a href="/people">People</a>
      <a href="/research">Research</a>
      <a href="/events">Events</a>
      <a href="/opportunities">Opportunities</a>
      <a href="/news">News</a>
    </div>

    <div class="site-footer__col">
      <h4>Contact</h4>
      <p class="meta">
        60 Garden St., MS 51<br />
        Cambridge, MA 02138<br />
        <a href="mailto:itcinfo@cfa.harvard.edu">itcinfo@cfa.harvard.edu</a>
      </p>
    </div>
  </div>
  <div class="container site-footer__base">
    <p class="meta">© {year} The President and Fellows of Harvard College</p>
    <p class="meta">
      <a href="https://www.cfa.harvard.edu/">Center for Astrophysics</a> ·
      <a href="https://accessibility.huit.harvard.edu/digital-accessibility-policy">Accessibility</a>
    </p>
  </div>
</footer>

<style>
  .site-footer { background: var(--ink); color: #cfd3da; margin-top: 4rem; }
  .site-footer a { color: #cfd3da; }
  .site-footer a:hover { color: #fff; }
  .site-footer__inner {
    display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 2.5rem;
    padding-block: 3rem 2rem;
  }
  .site-footer__brand { display: flex; gap: 1rem; align-items: flex-start; max-width: 360px; }
  .site-footer__brand .brand__mark {
    font-family: var(--font-serif); font-weight: 700; color: #fff; background: var(--accent);
    width: 42px; height: 42px; border-radius: 8px; display: grid; place-items: center; flex-shrink: 0;
  }
  .site-footer__brand strong { color: #fff; font-family: var(--font-serif); }
  .site-footer__col { display: flex; flex-direction: column; gap: .4rem; }
  .site-footer__col h4 { color: #fff; font-size: .8rem; text-transform: uppercase; letter-spacing: .1em; margin-bottom: .5rem; font-family: var(--font-sans); }
  .site-footer__col a { font-size: .92rem; }
  .site-footer__base {
    display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
    border-top: 1px solid rgba(255,255,255,.12); padding-block: 1.25rem 2rem;
  }
  .site-footer__base .meta { color: #8c919b; }
  @media (max-width: 700px) {
    .site-footer__inner { grid-template-columns: 1fr 1fr; }
    .site-footer__brand { grid-column: 1 / -1; }
  }
</style>
