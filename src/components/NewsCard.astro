---
import { url } from "../lib/url.js";
const { item } = Astro.props;
const { title, date, url: href, excerpt, image } = item;
const fmt = date
  ? new Date(date + "T00:00:00").toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })
  : null;
---
<article class="news card">
  <a href={href} class="news__link">
    {image && (
      <div class="news__media">
        <img src={url(image)} alt="" loading="lazy" />
      </div>
    )}
    <div class="news__body">
      {fmt && <time class="news__date" datetime={date}>{fmt}</time>}
      <h3 class="news__title">{title}</h3>
      {excerpt && <p class="news__excerpt">{excerpt}</p>}
      <span class="arrow-link news__more">Read more</span>
    </div>
  </a>
</article>

<style>
  .news { height: 100%; }
  .news__link { display: flex; flex-direction: column; height: 100%; color: inherit; }
  .news__link:hover { text-decoration: none; }
  .news__media { width: 100%; flex: none; overflow: hidden; background: var(--bg-sky); }
  .news__media img { display: block; width: 100%; aspect-ratio: 4 / 3; object-fit: cover; transition: transform .4s ease; }
  .news:hover .news__media img { transform: scale(1.04); }
  .news__body { display: flex; flex-direction: column; height: 100%; padding: 1.25rem 1.4rem 1.5rem; }
  .news__date { display: block; margin-bottom: .55rem; font-size: .72rem; text-transform: uppercase; letter-spacing: .06em; color: var(--ink-faint); }
  .news__title { font-size: 1.15rem; margin: 0 0 .5rem; }
  .news__excerpt { color: var(--ink-soft); font-size: .92rem; margin: 0 0 1rem; flex: 1; }
  .news__more { font-size: .9rem; }
</style>
