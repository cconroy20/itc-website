---
const { title } = Astro.props;
---
<div class="page-title container">
  <h1 set:html={title} />
  <span class="page-title__rule" aria-hidden="true"></span>
</div>

<style>
  /* No banner — the page title opens the content inline. */
  .page-title {
    padding-block: clamp(2rem, 4vw, 2.75rem) 0;
  }
  .page-title h1 {
    margin: 0;
    font-size: clamp(2.1rem, 4.5vw, 3rem);
    letter-spacing: -0.03em;
  }
  .page-title__rule {
    display: block; width: 3rem; height: 3px; margin-top: .9rem;
    background: var(--grad); border-radius: 2px;
  }
</style>
