---
const { path = "" } = Astro.props;
const nav = [
  { label: "About", href: "/about" },
  { label: "People", href: "/people" },
  { label: "Alumni", href: "/alumni" },
  { label: "Research", href: "/research" },
  { label: "Events", href: "/events" },
  { label: "Opportunities", href: "/opportunities" },
  { label: "News", href: "/news" },
];
const isActive = (href) => path === href || (href !== "/" && path.startsWith(href));
---
<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="/" aria-label="ITC — Institute for Theory and Computation, home">
      <svg class="brand__mark" viewBox="-1 12 74 35" role="img" aria-hidden="true" preserveAspectRatio="xMinYMid meet">
        <text x="0" y="44" class="brand__mark-text">ITC</text>
      </svg>
      <span class="brand__text">
        <strong>Institute for Theory &amp; Computation</strong>
        <small>Center for Astrophysics | Harvard &amp; Smithsonian</small>
      </span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" hidden />
    <label for="nav-toggle" class="nav-toggle__btn" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="site-nav" aria-label="Primary">
      {nav.map((item) => (
        <a href={item.href} class:list={["site-nav__link", { "is-active": isActive(item.href) }]}>
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(255,255,255,.9);
    backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .site-header__inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: clamp(1rem, 3vw, 2rem); min-height: 72px;
  }
  .brand {
    display: flex; align-items: center; gap: .7rem; color: var(--ink);
    /* logo height = the two text lines' box: (1.3 + 0.72) * 1.2 line-height.
       The viewBox is trimmed to the ITC cap-band, so SVG height maps 1:1 to
       cap height — caps match the text block, and both scale with rem at any zoom. */
    --brand-h: calc((1.5rem + 0.72rem) * 1.2);
  }
  .brand:hover { text-decoration: none; }
  .brand__mark {
    height: var(--brand-h); width: auto; flex-shrink: 0; display: block;
  }
  .brand__mark-text {
    font-family: var(--font-serif); font-weight: 700; font-size: 46px;
    letter-spacing: .01em; fill: currentColor;
  }
  .brand__text { display: flex; flex-direction: column; line-height: 1.2; }
  .brand__text strong { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 600; white-space: nowrap; }
  .brand__text small {
    color: var(--ink-faint); font-size: .72rem; white-space: nowrap;
    font-family: var(--font-sans); font-weight: 500; letter-spacing: .01em;
  }

  .site-nav { display: flex; align-items: center; gap: .2rem; }
  .site-nav__link {
    position: relative;
    color: var(--ink-soft); font-weight: 500; font-size: .92rem;
    padding: .5rem .25rem; margin-inline: .22rem; border-radius: 0;
  }
  .site-nav__link::after {
    content: ""; position: absolute; left: .25rem; right: .25rem; bottom: -2px;
    height: 2px; background: var(--grad); transform: scaleX(0); transform-origin: left;
    transition: transform .18s ease;
  }
  .site-nav__link:hover { color: var(--ink); text-decoration: none; }
  .site-nav__link:hover::after { transform: scaleX(1); }
  .site-nav__link.is-active { color: var(--ink); font-weight: 600; }
  .site-nav__link.is-active::after { transform: scaleX(1); }

  .nav-toggle__btn { display: none; }

  @media (max-width: 880px) {
    .brand__text small { display: none; }
    .brand__text strong { font-size: 1.05rem; white-space: normal; }
    .nav-toggle__btn {
      display: flex; flex-direction: column; gap: 5px; cursor: pointer;
      padding: .5rem; margin: -.5rem;
    }
    .nav-toggle__btn span { width: 24px; height: 2px; background: var(--ink); border-radius: 2px; }
    .site-nav {
      position: absolute; top: 100%; left: 0; right: 0;
      flex-direction: column; align-items: stretch;
      background: #fff; border-bottom: 1px solid var(--line);
      padding: .75rem 1rem 1.25rem; gap: .25rem;
      display: none; box-shadow: var(--shadow);
    }
    .nav-toggle:checked ~ .site-nav { display: flex; }
    .site-nav__link { padding: .75rem; margin-inline: 0; font-size: 1rem; }
    .site-nav__link::after { display: none; }
    .site-nav__link:hover { background: var(--bg-soft); }
  }

  /* Very narrow phones: drop the long name, keep just the ITC mark */
  @media (max-width: 460px) {
    .brand__text strong { font-size: .95rem; }
    .site-header__inner { gap: .75rem; }
  }
</style>
